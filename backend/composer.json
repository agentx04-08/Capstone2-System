{
  "name": "unick-enterprises/backend",
  "description": "Unick Enterprises Inc. Order, Inventory, Production System",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0",
    "maatwebsite/excel": "^3.1",
    "barryvdh/laravel-dompdf": "^3.0"
  },
  "require-dev": {
    "nunomaduro/collision": "^8.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  }
}